# ─── Database Settings ────────────────────────────────────────────────────────
# Default: Local file-based SQLite database.
# Production PostgreSQL example: postgresql+psycopg2://user:pass@localhost:5432/db
DATABASE_URL=sqlite:///./shopfloor.db

# ─── Security Settings ────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Generate a secure one in production:
# Command: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-secure-32-bytes-key-!!!

# ─── Redis / Celery Task Queue ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Frontend Environment (for next.config.ts / next dev) ─────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
